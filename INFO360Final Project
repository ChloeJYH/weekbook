<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Week Book App</title>
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@700&family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-yellow: #FFF9E5;
            --accent-brown: #4A3728;
            --card-white: #FFFFFF;
            --text-main: #4A3728;
            --btn-orange: #F3A953;
            --soft-red: #FFB5B5;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        
        body {
            font-family: 'Inter', sans-serif;
            background-color: #F0F0F0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            color: var(--text-main);
        }

        /* Mobile Container */
        .phone-container {
            width: 375px;
            height: 667px;
            background-color: var(--bg-yellow);
            border: 8px solid #333;
            border-radius: 40px;
            position: relative;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        }

        .screen {
            display: none;
            flex-direction: column;
            padding: 40px 25px;
            height: 100%;
        }

        .screen.active { display: flex; }

        /* Typography */
        h1 { font-family: 'Caveat', cursive; font-size: 3rem; margin-bottom: 10px; }
        .tagline { font-style: italic; font-size: 0.9rem; margin-bottom: 40px; opacity: 0.8; }

        /* Buttons */
        .btn-main {
            background-color: var(--accent-brown);
            color: white;
            border: none;
            padding: 15px;
            border-radius: 25px;
            font-weight: 600;
            cursor: pointer;
            width: 100%;
            margin-top: auto;
        }

        /* Home Screen Elements */
        .dashboard-card {
            background: white;
            border-radius: 20px;
            padding: 20px;
            margin-bottom: 20px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        }

        .chart-placeholder {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            border: 10px solid var(--btn-orange);
            margin: 10px auto;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
        }

        /* Task List */
        .task-item {
            background: white;
            border-radius: 15px;
            padding: 15px;
            margin-bottom: 10px;
            border-left: 5px solid var(--btn-orange);
        }

        .task-meta { font-size: 0.7rem; color: #888; margin-top: 5px; }

        /* Navigation Bar */
        .nav-bar {
            position: absolute;
            bottom: 0;
            width: 100%;
            height: 60px;
            background: white;
            display: flex;
            justify-content: space-around;
            align-items: center;
            border-top: 1px solid #eee;
        }

        .nav-item { font-size: 0.7rem; cursor: pointer; text-align: center; color: #999; }
        .nav-item.active { color: var(--accent-brown); font-weight: bold; }
    </style>
</head>
<body>

<div class="phone-container">
    
    <div id="landing" class="screen active">
        <div style="text-align: center; margin-top: 80px;">
            <div style="font-size: 40px; margin-bottom: 20px;">📓</div>
            <h1>Week Book</h1>
            <p class="tagline">"A journal that moves with your deadlines"</p>
        </div>
        <button class="btn-main" onclick="showScreen('home')">Get started</button>
        <p style="text-align: center; font-size: 0.7rem; margin-top: 15px;">
            Already have an account? <span style="text-decoration: underline; color: var(--btn-orange);">Log in</span>
        </p>
    </div>

    <div id="home" class="screen">
        <h3>Hi Alex 👋</h3>
        <p style="font-size: 0.8rem; margin-bottom: 20px;">Wed, Mar 4 - Week 9</p>
        
        <div class="dashboard-card">
            <p style="font-size: 0.7rem; font-style: italic;">"You have 3 assignments due this week. Start with the hardest one first."</p>
            <div class="chart-placeholder">4/10</div>
        </div>

        <h4>THIS WEEK</h4>
        <div class="task-item">Essay Draft <div class="task-meta">Due in 2 days</div></div>
        <div class="task-item">Reading #3 <div class="task-meta">Due in 4 days</div></div>

        <div class="nav-bar">
            <div class="nav-item active">Home</div>
            <div class="nav-item" onclick="showScreen('tasks')">Tasks</div>
            <div class="nav-item">Design</div>
        </div>
    </div>

    <div id="tasks" class="screen">
        <h3>My tasks</h3>
        <p style="font-size: 0.8rem; margin-bottom: 20px; color: #d9534f;">3 due in this week</p>
        
        <p style="font-weight: bold; font-size: 0.8rem; margin-bottom: 10px;">TODAY</p>
        <div class="task-item" style="border-color: #ffb5b5;">
            Reading #3
            <div class="task-meta">Due in 3 hours - INFO 200</div>
        </div>

        <p style="font-weight: bold; font-size: 0.8rem; margin-top: 15px; margin-bottom: 10px;">UPCOMING</p>
        <div class="task-item" style="border-color: #eee;">
            Quiz 1
            <div class="task-meta">Due in 10 days - MATH 126</div>
        </div>

        <button style="background: none; border: 1px dashed #aaa; padding: 10px; border-radius: 10px; margin-top: 10px;">+ Add a task...</button>

        <div class="nav-bar">
            <div class="nav-item" onclick="showScreen('home')">Home</div>
            <div class="nav-item active">Tasks</div>
            <div class="nav-item">Design</div>
        </div>
    </div>

</div>

<script>
    function showScreen(screenId) {
        // Hide all screens
        const screens = document.querySelectorAll('.screen');
        screens.forEach(s => s.classList.remove('active'));
        
        // Show selected screen
        document.getElementById(screenId).classList.add('active');
    }
</script>

</body>
</html>
